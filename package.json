{
  "name": "api-test-automation-cypress",
  "version": "1.2.0",
  "description": "Testes automatizados de API utilizando Cypress",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test:smoke": "cypress run --spec \"cypress/e2e/**/*.smoke.cy.js\"",
    "test:regression": "cypress run --spec \"cypress/e2e/**/*.regression.cy.js\"",
    "test:all": "cypress run --spec \"cypress/e2e/**/*.cy.js\""
  },
  "devDependencies": {
    "chai-json-schema": "^1.5.1",
    "cypress": "^13.14.2"
  }
}
